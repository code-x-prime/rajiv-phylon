// Prisma schema for B2B Rajiv Phylon
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------
// Admin (B2B - admin login only, no public auth)
// -----------------------------------------------
model Admin {
  id                String            @id @default(cuid())
  email             String            @unique
  password          String
  name              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  updatedInquiries  ContactInquiry[]

  @@map("admins")
}

// -----------------------------------------------
// Category
// -----------------------------------------------
model Category {
  id                 String            @id @default(cuid())
  name               String
  slug               String            @unique
  image              String?           // R2 key or URL
  showOnHome         Boolean           @default(false)
  homeOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  subCategories      SubCategory[]
  productCategories  ProductCategory[]

  @@map("categories")
}

// -----------------------------------------------
// SubCategory (linked to Category)
// -----------------------------------------------
model SubCategory {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  image                 String?                // R2 key or URL
  categoryId            String
  category              Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  productSubCategories  ProductSubCategory[]

  @@map("sub_categories")
}

// -----------------------------------------------
// Product ↔ Category (many-to-many junction)
// -----------------------------------------------
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

// -----------------------------------------------
// Product ↔ SubCategory (many-to-many junction)
// -----------------------------------------------
model ProductSubCategory {
  productId     String
  subCategoryId String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@id([productId, subCategoryId])
  @@map("product_sub_categories")
}

// -----------------------------------------------
// Product feature tag (home sections)
// -----------------------------------------------
enum ProductFeature {
  NEW_ARRIVAL
  TRENDING
  BEST_SELLER
}

// -----------------------------------------------
// Product (many categories, many subcategories)
// -----------------------------------------------
model Product {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  description          String?               @db.Text // Jodit HTML content
  metaTitle            String?               // SEO; auto from name if empty
  metaDescription      String?               @db.Text // SEO; auto from description if empty
  metaKeywords         String?               @db.Text // SEO; auto from name + categories if empty
  ogImage              String?               // OpenGraph image URL; auto from first product image if empty
  featureTag           ProductFeature?      // legacy; prefer isNewArrival / isHighDemand
  isFeatured           Boolean               @default(false)
  isNewArrival         Boolean               @default(false)
  isHighDemand         Boolean               @default(false)
  showOnHome           Boolean               @default(false)
  isActive             Boolean               @default(true)
  moq                  String?               // Minimum Order Quantity, e.g. "1200-2400 Pairs"
  specifications       String?               @db.Text  // JSON string: { "Material": "TPR", "Color": "Brown" }
  tradeInfo            String?               @db.Text  // JSON string: { "Payment Terms": "T/T", "Supply Ability": "100000 per day" }
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  images               ProductImage[]
  productCategories    ProductCategory[]
  productSubCategories ProductSubCategory[]

  @@map("products")
}

// -----------------------------------------------
// Banner (home hero – desktop + mobile images)
// -----------------------------------------------
model Banner {
  id            String   @id @default(cuid())
  title         String
  desktopImage  String   // R2 key or URL
  mobileImage   String   // R2 key or URL
  link          String?
  position      String?  // e.g. HOME_DESKTOP; optional, filter client by this
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("banners")
}

// -----------------------------------------------
// ProductImage (max 4 per product, with position)
// -----------------------------------------------
model ProductImage {
  id        String   @id @default(cuid())
  url       String   // R2 public URL or key
  position  Int      @default(0) // 0..3 for ordering
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// -----------------------------------------------
// Gallery
// -----------------------------------------------
model Gallery {
  id        String   @id @default(cuid())
  image     String   // R2 key or URL
  title     String?
  section   String?  // e.g. INFRASTRUCTURE for factory/infra gallery on home
  createdAt DateTime @default(now())

  @@map("galleries")
}

// -----------------------------------------------
// ContactInquiry (from client contact form) – CRM
// -----------------------------------------------
enum InquiryStatus {
  PENDING
  CONTACTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model ContactInquiry {
  id              String        @id @default(cuid())
  name            String
  phone           String
  email           String?
  message         String        @db.Text
  quantity        String?
  unit            String?
  productId       String?
  productName     String?
  source          String?       // e.g. "contact-page", "product-detail"
  status          InquiryStatus @default(PENDING)
  adminNotes      String?       @db.Text
  followUpDate    DateTime?
  lastUpdatedById String?
  lastUpdatedBy   Admin?        @relation(fields: [lastUpdatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("contact_inquiries")
}
